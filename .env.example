# Copy to .env locally if needed. Do not commit real secrets.

NODE_ENV=development
PORT=8080

# Required for Telegram webhook validation and outbound replies.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google Cloud / Vertex AI target.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# Safety mode keeps the service from sending Telegram replies.
DRY_RUN=true
